generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  resetSenhaToken    String?
  resetSenhaExpiraEm DateTime?
  criadoEm DateTime @default(now())

  tarefas   Tarefa[]
}

model Tarefa {
  id           Int       @id @default(autoincrement())
  titulo       String
  descricao    String?
  feita        Boolean   @default(false)
  dataLembrete DateTime?
  emailEnviado Boolean   @default(false)
  criadoEm     DateTime  @default(now())

  usuarioId    Int
  usuario      Usuario   @relation(fields: [usuarioId], references: [id])
}